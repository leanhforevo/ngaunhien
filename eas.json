{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "autoIncrement": true
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "staging"
    },
    "production": {
      "distribution": "store",
      "channel": "prod-v1",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {},
      "ios": {
        "appleId": "leanhforevo@gmail.com",
        "appleTeamId": "G8ZLW97GRP"
      }
    }
  }
}
