  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev": "npx expo start --dev-client -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "build:android": "npx eas-cli@latest build --platform android --profile production --non-interactive",
    "build:ios": "npx eas-cli@latest build --platform ios --profile production --non-interactive",
    "build:android:dev": "npx eas-cli@latest build --platform android --profile development --non-interactive",
    "build:ios:dev": "npx eas-cli@latest build --platform ios --profile development --non-interactive",
    "submit:android": "npx eas-cli@latest submit --platform android",
    "submit:ios": "npx eas-cli@latest submit --platform ios --latest",
    "update:dev": "npx eas-cli@latest update --channel dev",
    "update:production": "npx eas-cli@latest update --channel production"
  },
